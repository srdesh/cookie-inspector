{
  "manifest_version": 3,
  "name": "Cookie Inspector",
  "version": "1.0",
  "description": "Classifies cookies, detects risk, and allows users to reset cookie preferences.",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}